@page "/bank-upload"
@* @using Blazorise *@
@rendermode InteractiveServer
@inject IJSRuntime JS
@implements IAsyncDisposable


<PageTitle>Bank Statement Converter</PageTitle>


<div class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-5"><h1 class="text-3xl font-bold text-gray-800 mb-2">Bank Statement Converter</h1><p class="text-gray-600">Upload your bank statement CSV to convert for ERP import</p></div><div id="uploadSection" class="bg-white rounded-lg shadow-lg p-3">
            <div id="dropZone" class="border-4 border-dashed border-gray-300 rounded-lg p-3 text-center">
                <p class="text-xl font-semibold text-gray-700 mb-4">Drop your CSV here or</p><input type="file" id="fileInput" accept=".csv" class="hidden" />

                <p class="text-sm text-gray-400 mt-4">CSV files only</p>
            </div><div id="errorMsg" class="hidden"></div>
        </div>
        <div id="resultsSection" class="hidden space-y-6 mt-5">
            <div class="bg-white rounded-lg shadow-lg p-3">
                <div>
                    <h3 id="fileName" class="text-3xl font-bold text-gray-800 mb-2"></h3>
                </div>
                <button style="outline-color: red" id="clearButton">Clear Data </button>
            </div>
            <div class="bg-white rounded-lg shadow-lg p-3">
                <h4 class="font-semibold text-amber-900 mb-4">Reconciliation Check</h4>
                <table class="w-full border border-gray-200 rounded-lg text-sm">
                    <thead class="bg-gray-100">
                        <tr>
                            <th class="px-4 py-3 text-left">Check</th>
                            <th class="px-4 py-3 text-left">Bank Statement</th>
                            <th class="px-4 py-3 text-left">Output</th>
                            <th class="px-4 py-3 text-left">Status</th>
                        </tr>
                    </thead>
                    <tbody id="tableData">
                        <tr class="border-t border-gray-200">
                            <td class="px-4 py-3">Number of Records</td>
                            <td class="px-4 py-3" id="bankCount"></td>
                            <td class="px-4 py-3" id="outputCount"></td>
                            <td class="px-4 py-3" id="countStatus"></td>
                        </tr>
                        <tr class="border-t border-gray-200">
                            <td class="px-4 py-3">Absolute Total Amount</td>
                            <td class="px-4 py-3" id="bankTotal"></td>
                            <td class="px-4 py-3" id="outputTotal"></td>
                            <td class="px-4 py-3" id="amountStatus"></td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="bg-white rounded-lg shadow-lg  text-center">
            <button id="downloadButton" style="height: 45px; margin: 15px; outline-color: dodgerblue"> 📥 Download Converted CSV </button>
                <p id="recordCount" class="text-sm text-gray-600 mt-3"></p>
            </div>
        </div>
    </div>
</div>
 


@code {
    private IJSObjectReference? _module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./Components/Pages/UploadExpense.razor.js");

            await _module.InvokeVoidAsync("initializeBankStatementUpload");
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
            await _module.DisposeAsync();
    }

}