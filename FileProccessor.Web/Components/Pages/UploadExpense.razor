<PageTitle>Bank Statement Converter</PageTitle>
<h3>Bank Statement Converter</h3>

<body class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50 p-8">
    <div class="max-w-7xl mx-auto">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800 mb-2">Bank Statement Converter</h1>
            <p class="text-gray-600">Upload your bank statement CSV to convert for ERP import</p>
        </div>

        <!-- Upload Section -->
        <div id="uploadSection" class="bg-white rounded-lg shadow-lg p-8">
            <div class="border-4 border-dashed border-gray-300 rounded-lg p-12 text-center"
                 id="dropZone">
                <p class="text-xl font-semibold text-gray-700 mb-4">Drop your CSV here or</p>
                <input type="file" id="fileInput" accept=".csv" class="hidden" />
                <button onclick="document.getElementById('fileInput').click()"
                        class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors">
                    Browse Files
                </button>
                <p class="text-sm text-gray-400 mt-4">CSV files only</p>
            </div>
            <div id="errorMsg" class="hidden mt-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700"></div>
        </div>

        <!-- Results Section -->
        <div id="resultsSection" class="hidden space-y-6 mt-6">
            <div class="bg-white rounded-lg shadow-lg p-6 flex items-center justify-between">
                <div>
                    <h3 id="fileName" class="text-lg font-semibold text-gray-800"></h3>
                    <p class="text-sm text-gray-500">File uploaded successfully</p>
                </div>
                <button onclick="clearData()"
                        class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors">
                    Clear Data
                </button>
            </div>

            <!-- Reconciliation -->
            <div class="bg-white rounded-lg shadow-lg p-6">
                <h4 class="font-semibold text-amber-900 mb-4">Reconciliation Check</h4>
                <table class="w-full border border-gray-200 rounded-lg text-sm">
                    <thead class="bg-gray-100">
                        <tr>
                            <th class="px-4 py-3 text-left">Check</th>
                            <th class="px-4 py-3 text-left">Bank Statement</th>
                            <th class="px-4 py-3 text-left">Output</th>
                            <th class="px-4 py-3 text-left">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="border-t border-gray-200">
                            <td class="px-4 py-3">Number of Records</td>
                            <td class="px-4 py-3" id="bankCount">-</td>
                            <td class="px-4 py-3" id="outputCount">-</td>
                            <td class="px-4 py-3" id="countStatus">-</td>
                        </tr>
                        <tr class="border-t border-gray-200">
                            <td class="px-4 py-3">Absolute Total Amount</td>
                            <td class="px-4 py-3" id="bankTotal">-</td>
                            <td class="px-4 py-3" id="outputTotal">-</td>
                            <td class="px-4 py-3" id="amountStatus">-</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Download -->
            <div class="bg-white rounded-lg shadow-lg p-6 text-center">
                <button onclick="downloadFile()"
                        class="inline-flex items-center gap-2 px-8 py-4 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors font-semibold text-lg">
                    ⬇ Download Converted CSV
                </button>
                <p id="recordCount" class="text-sm text-gray-600 mt-3"></p>
            </div>
        </div>
    </div>
