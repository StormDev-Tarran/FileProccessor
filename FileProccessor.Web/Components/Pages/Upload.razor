<PageTitle>Payshap Statement Converter</PageTitle>
@if (_result is null)
{
    
    <div class="text-center mb-8">
        @* <div style="margin-bottom: 1rem; " class="text-end mb-8 btn-danger">
            <button @onclick="ClearData">Clear</button>
        </div> *@
        <h1 class="text-3xl font-bold text-gray-800 mb-2">File Processor</h1>
        <p class="text-gray-600">Upload your payshap document to convert</p>
        <div style="margin-bottom: 1rem;">
            <InputFile OnChange="HandleFileSelected" accept=".csv,.xlsx,.xls" />
            <button @onclick="ProcessFileAsync" disabled="@(_selectedFile is null || _isProcessing)">
