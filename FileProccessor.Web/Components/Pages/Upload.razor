        <div style="margin-bottom: 1rem;">
            <InputFile OnChange="HandleFileSelected" accept=".csv,.xlsx,.xls" />
            <button @onclick="ProcessFileAsync" disabled="@(_selectedFile is null || _isProcessing)">
                @(_isProcessing ? "Processing..." : "Process File")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <div style="margin-bottom: 1rem; color:@(_isError ? "red" : "green");">
                @_message
            </div>
        }
    </div>
    <div style="margin-bottom: 1rem; ">
        <button @onclick="DownloadResultAsync">Download Output File</button>
        <button @onclick="ClearData">Clear</button>
    </div>
    @* <div style="margin-bottom: 1.5rem;">
        <button @onclick="DownloadResultAsync">Download Output File</button>
    </div> *@

    <h4>Bank Statement Preview - First 3 Rows</h4>

    @if (_result.Headers.Any() && _result.PreviewRows.Any())
    {
        <div style="overflow-x:auto; margin-bottom: 1.5rem;">
            <table border="1" cellpadding="6" style="border-collapse: collapse; width: 100%;">
                <thead>
                    <tr>
                        <th>Row</th>
                        @for (int i = 0; i < _result.Headers.Count; i++)
                        {
                            var headerUpper = (_result.Headers[i] ?? "").ToUpperInvariant();
                            if (headerUpper == "DEBITS" || headerUpper == "CREDITS" || headerUpper == "DEBIT" || headerUpper == "CREDIT")
                            {
                                continue;
                            }

                            <th>@_result.Headers[i]</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @for (int rowIndex = 0; rowIndex < _result.PreviewRows.Count; rowIndex++)
                    {
                        var row = _result.PreviewRows[rowIndex];
                        <tr>
                            <td>@(rowIndex + 1)</td>

                            @for (int cellIndex = 0; cellIndex < row.Count; cellIndex++)
                            {
                                var headerUpper = cellIndex < _result.Headers.Count
                                ? (_result.Headers[cellIndex] ?? "").ToUpperInvariant()
                                : "";

                                if (headerUpper == "DEBITS" || headerUpper == "CREDITS" || headerUpper == "DEBIT" || headerUpper == "CREDIT")
                                {
                                    continue;
                                }

                                <td>@row[cellIndex]</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <h4>Output Preview - First 3 Rows</h4>

    @* @if (_result.OutputPreview.Any())
    {
        <div style="overflow-x:auto; margin-bottom: 1.5rem;">
            <table border="1" cellpadding="6" style="border-collapse: collapse; width: 100%;">
                <thead>
                    <tr>
