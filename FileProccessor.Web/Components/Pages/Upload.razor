                        <th>Description</th>
                        <th>Reference</th>
                        <th>Amount</th>
                        <th>UseTax</th>
                        <th>TaxType</th>
                        <th>TaxAccount</th>
                        <th>TaxAmount</th>
                        <th>Project</th>
