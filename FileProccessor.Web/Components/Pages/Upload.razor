                                <td>@row.PostDated</td>
                                <td>@row.UseDiscount</td>
                                <td>@row.DiscPerc</td>
                                <td>@row.DiscTrCode</td>
                                <td>@row.DiscDesc</td>
                                <td>@row.UseDiscTax</td>
                                <td>@row.DiscTaxType</td>
                                <td>@row.DiscTaxAcc</td>
                                <td>@row.DiscTaxAmt</td>
                                <td>@row.PayeeName</td>
                                <td>@row.PrintCheque</td>
                                <td>@row.SalesRep</td>
                                <td>@row.Module</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    <h4>Reconciliation Check</h4>

    <table border="1" cellpadding="6" style="border-collapse: collapse; margin-bottom: 1rem;">
        <thead>
            <tr>
                <th>Check</th>
                <th>Bank Statement File</th>
                <th>Output File</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Number of Records</td>
                <td>@_result.BankStatementCount</td>
                <td>@_result.AllOutputRows.Count</td>
                <td>@(_result.RecordsMatch ? "Match" : "Error")</td>
            </tr>
            <tr>
                <td>Absolute Total Amount</td>
                <td>@_result.BankStatementTotal.ToString("0.00")</td>
                <td>@_result.OutputTotal.ToString("0.00")</td>
                <td>@(_result.TotalsMatch ? "Match" : "Error")</td>
            </tr>
        </tbody>
    </table>

    @if (_result.RecordsMatch && _result.TotalsMatch)
    {
        <div style="color: green; margin-bottom: 1rem;">
            Reconciliation Successful! All records and amounts match.
        </div>
    }
    else
    {
        <div style="color: red; margin-bottom: 1rem;">
            Reconciliation Failed! Please review the discrepancies above.
        </div>
    }
}

@code {
    private IBrowserFile? _selectedFile;
    private ResultModel? _result;
    private string _message = "";
    private bool _isError;
    private bool _isProcessing;
    private IJSObjectReference? _module;

    //private AccountModel? accountModel;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./Components/Pages/Upload.razor.js");
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _result = null;
        _message = $"Selected: {_selectedFile?.Name}";
        _isError = false;
    }

    private async Task ProcessFileAsync()
    {
        if (_selectedFile is null)
        {
            _message = "Please select a valid file.";
            _isError = true;
            return;
        }

        try
        {
            _isProcessing = true;
            _message = "";
            _isError = false;

            await using var stream = _selectedFile.OpenReadStream(20 * 1024 * 1024);
            _result = await FileProcessorService.ProccessFileAsync(stream, _selectedFile.Name);

            

            _message = "File processed successfully.";
        }
        catch (Exception ex)
        {
            _result = null;
            _message = $"Error: {ex.GetType().Name}: {ex.Message}";
            _isError = true;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task DownloadResultAsync()
    {
        if (_result is null || _module is null)
            return;

        var base64 = Convert.ToBase64String(_result.FileData);

        await _module.InvokeVoidAsync(
            "downloadFile",
            _result.FileName,
            _result.ContentType,
            base64);
    }
    private void ClearData()
    {
        _selectedFile = null;
        _result = null;
        _message = "";
        _isError = false;
        _isProcessing = false;

    }
}